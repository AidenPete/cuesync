# OpenAI — required for the shop assistant chatbot
OPENAI_API_KEY=sk-your-key-here

# Optional — defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# OTP session signing — set a long random string in production
JWT_SECRET=change-me-in-production

# Admin portal password (required in production)
ADMIN_PASSWORD=your-secure-admin-password

# Or use a bcrypt hash instead of plain password:
# ADMIN_PASSWORD_HASH=$2a$10$...
